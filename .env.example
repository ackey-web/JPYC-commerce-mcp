# =============================================================================
# JPYC Commerce MCP — 環境変数サンプル
# =============================================================================
# このファイルをコピーして .env を作成し、各値を実際の値に置き換えてください。
#   cp .env.example .env
#
# ⚠️  .env は絶対に Git にコミットしないこと（.gitignore に記載済み）
# =============================================================================


# -----------------------------------------------------------------------------
# データベース (Neon PostgreSQL) — 必須
# -----------------------------------------------------------------------------
# Neon コンソール > Project > Connection string からコピー
# sslmode=require は Neon 接続に必須
DATABASE_URL=postgres://user:password@ep-example-123456.ap-southeast-1.aws.neon.tech/neondb?sslmode=require


# -----------------------------------------------------------------------------
# AI / Claude API — 必須
# -----------------------------------------------------------------------------
# https://console.anthropic.com/settings/keys で発行
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# -----------------------------------------------------------------------------
# ブロックチェーン RPC — 必須
# -----------------------------------------------------------------------------
# Polygon Mainnet (Chain ID: 137)
POLYGON_RPC_URL=https://polygon-rpc.com

# Polygon Amoy Testnet (Chain ID: 80002) — Phase 0 テスト環境
AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# 使用するチェーン ID（開発: 80002 / 本番: 137）
CHAIN_ID=80002


# -----------------------------------------------------------------------------
# JPYC コントラクト — 必須
# -----------------------------------------------------------------------------
# Polygon Mainnet の JPYC v2 ERC-20 コントラクトアドレス
JPYC_CONTRACT_ADDRESS=0x431D5dfF03120AFA4bDf332c61A6e1766eF37BF


# -----------------------------------------------------------------------------
# TrustSBT コントラクト — 必須（デプロイ後に設定）
# -----------------------------------------------------------------------------
# Amoy testnet デプロイアドレス（smart-contract-engineer がデプロイ後に更新）
SBT_CONTRACT_ADDRESS_AMOY=0x0000000000000000000000000000000000000000

# Polygon Mainnet デプロイアドレス（Phase 0+ 完了後に設定）
SBT_CONTRACT_ADDRESS_MAINNET=0x0000000000000000000000000000000000000000


# -----------------------------------------------------------------------------
# BountyEscrow コントラクト — 必須（デプロイ後に設定）
# -----------------------------------------------------------------------------
# Amoy testnet デプロイアドレス（npm run deploy:bounty --network amoy 実行後に更新）
BOUNTY_ESCROW_ADDRESS_AMOY=0x0000000000000000000000000000000000000000

# Polygon Mainnet デプロイアドレス（Phase 1 以降に設定）
BOUNTY_ESCROW_ADDRESS_MAINNET=0x0000000000000000000000000000000000000000

# Amoy testnet 上の JPYC テストトークンアドレス（MockJPYC デプロイ後に設定）
JPYC_ADDRESS_AMOY=0x0000000000000000000000000000000000000000

# BountyEscrow の admin ウォレットアドレス（省略時はデプロイアドレスが admin になる）
# BOUNTY_ADMIN_ADDRESS=0x...


# -----------------------------------------------------------------------------
# Merkle Root コミット用運営ウォレット — 必須（運営者のみ）
# -----------------------------------------------------------------------------
# ノンカストディアル原則の唯一の例外：Merkle Root をオンチェーンにコミットする運営 EOA
# ユーザー資産とは完全分離した専用ウォレットを使用すること
# 秘密鍵は絶対にコードやログに含めないこと
MERKLE_COMMIT_PRIVATE_KEY=0xaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa


# -----------------------------------------------------------------------------
# アプリケーション設定 — オプション（デフォルト値あり）
# -----------------------------------------------------------------------------
# 実行環境（development / production）
NODE_ENV=development

# ログレベル（debug / info / warn / error）
LOG_LEVEL=info


# -----------------------------------------------------------------------------
# テスト・開発用フラグ — オプション（本番では必ず false）
# -----------------------------------------------------------------------------
# true にすると人間承認ステップをバイパスする（SEC-3 対応、テスト専用）
# 本番環境では絶対に false のままにすること
INSECURE_TEST_BYPASS_APPROVAL=false


# -----------------------------------------------------------------------------
# Pluggable Relayer — オプション（EIP-3009 ガスレス決済に使用）
# -----------------------------------------------------------------------------
# リレイヤーの種類を選択: "gelato" | "biconomy" | "custom"
# 未設定時は "custom" 扱い（RELAYER_URL へ直接 POST）
RELAYER_PROVIDER=custom

# カスタム / Biconomy リレイヤーのエンドポイント URL
# Gelato は自動エンドポイントを使用するため不要
RELAYER_URL=https://your-relayer-endpoint.example.com/relay

# リレイヤーの API キー
# Gelato: sponsor API key
# Biconomy: x-api-key ヘッダー値
# custom: Bearer トークン
RELAYER_API_KEY=your-relayer-api-key
